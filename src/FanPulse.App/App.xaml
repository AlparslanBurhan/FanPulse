<Application x:Class="FanPulse.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Koyu tema paleti (Aşama 3'te genişletilecek) -->
        <SolidColorBrush x:Key="Bg" Color="#FF1B1D23" />
        <SolidColorBrush x:Key="Panel" Color="#FF242731" />
        <SolidColorBrush x:Key="Text" Color="#FFE8EAF0" />
        <SolidColorBrush x:Key="TextDim" Color="#FF9AA0AE" />
        <SolidColorBrush x:Key="Accent" Color="#FF4C8DFF" />
    </Application.Resources>
</Application>
